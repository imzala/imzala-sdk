{
    "name": "imzala/imzala-php",
    "description": "imzala.org server-side SDK — templates, demands, embedded signing, timestamps, webhook verification.",
    "type": "library",
    "license": "proprietary",
    "homepage": "https://github.com/imzala/imzala-sdk",
    "authors": [
        {
            "name": "imzala.org",
            "email": "destek@imzala.org",
            "homepage": "https://imzala.org"
        }
    ],
    "support": {
        "issues": "https://github.com/imzala/imzala-sdk/issues",
        "source": "https://github.com/imzala/imzala-sdk"
    },
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Imzala\\": "src/",
            "Imzala\\Client\\": "generated/lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Imzala\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
