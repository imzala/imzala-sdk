node_modules
dist
*.log
.DS_Store

# Python (packages/python)
.venv
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
build/

# .NET (packages/dotnet)
bin/
obj/
*.user

# Java (packages/java) — packages/java/generated/.gitignore covers its own
# nested target/; this covers packages/java/target/ (the facade module's
# own Maven build output, a sibling of generated/, not nested under it).
target/
*.class

# PHP (packages/php) — a library package, so composer.lock is deliberately
# NOT committed either (consumers/CI resolve their own lock), same
# convention as this repo's other language packages having no committed
# lock file for their own dependency managers.
packages/php/vendor/
packages/php/composer.lock
.phpunit.result.cache
